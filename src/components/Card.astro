---
import type { CollectionEntry } from "astro:content";
import dayjs from "dayjs";
import { getPostUrl } from "@/utils/getPostPaths";
import { toTransitionName } from "@/utils/toTransitionName";

type Props = {
  variant?: "h2" | "h3";
} & CollectionEntry<"posts">;

const { variant: Heading = "h2", id, data, filePath } = Astro.props;

const { title, description, tags, pubDatetime, modDatetime } = data;

const dt = modDatetime && modDatetime > pubDatetime ? modDatetime : pubDatetime;
const date = dayjs(dt).format("D MMM YYYY");
const iso = dayjs(dt).toISOString();
---

<li class="border-border/70 border-b py-4">
  <div class="flex items-baseline justify-between gap-4">
    <a
      href={getPostUrl(id, filePath, Astro.currentLocale)}
      class="hover:text-accent text-lg font-medium transition-colors"
    >
      <Heading transition:name={toTransitionName(title)} class="inline">
        {title}
      </Heading>
    </a>
    <time
      datetime={iso}
      class="text-muted-foreground flex shrink-0 items-center gap-2 text-sm whitespace-nowrap"
    >
      <span class="bg-muted-foreground/60 inline-block size-1.5 rounded-full"></span>
      {date}
    </time>
  </div>
  {description && <p class="text-muted-foreground mt-1 text-sm">{description}</p>}
  {
    tags && tags.length > 0 && (
      <ul class="mt-2 flex flex-wrap gap-x-2 gap-y-1.5">
        {tags.map(tag => (
          <li class="text-muted-foreground bg-muted rounded px-2 py-0.5 text-xs">
            #{tag}
          </li>
        ))}
      </ul>
    )
  }
</li>
